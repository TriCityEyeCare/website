---
import BaseLayout from '@/layouts/BaseLayout.astro';

const services = [
  {
    name: 'Cataract surgery',
    detail:
      'Day-procedure cataract extraction with intraocular lens (IOL) implantation. We offer standard monofocal lenses as well as premium options — toric IOLs for astigmatism and presbyopia-correcting (multifocal / EDOF) lenses. Surgery is performed at Cambridge Memorial Hospital.',
    bullets: ['Premium IOL options', 'Toric lenses for astigmatism', 'Femtosecond-laser-assisted surgery available'],
  },
  {
    name: 'Medical retina',
    detail:
      'Diagnosis and treatment of retinal conditions — wet age-related macular degeneration, diabetic retinopathy and macular edema, retinal vein occlusions, and related disorders. In-clinic anti-VEGF injections and retinal laser.',
    bullets: ['Anti-VEGF injections', 'Retinal laser', 'OCT imaging on site'],
  },
  {
    name: 'Glaucoma',
    detail:
      'Medical management of glaucoma with topical therapy, selective laser trabeculoplasty (SLT), and referral for surgery when needed. Several of our surgeons have advanced training in glaucoma.',
    bullets: ['Drop therapy', 'SLT laser', 'Surgical referral pathway'],
  },
  {
    name: 'Diabetic eye care',
    detail:
      'Comprehensive screening and treatment for diabetic eye disease, including diabetic macular edema and proliferative diabetic retinopathy.',
    bullets: ['Dilated diabetic exam', 'Anti-VEGF treatment', 'Pan-retinal photocoagulation'],
  },
  {
    name: 'Comprehensive consults',
    detail:
      'Complex anterior-segment assessments, and management of red eye, dry eye, lid disease, and other general ophthalmic conditions.',
    bullets: ['Anterior segment', 'General ophthalmology'],
  },
];
---
<BaseLayout
  title="Services"
  description="Services offered at Tri-City Eye Care: cataract surgery, medical retina, glaucoma, diabetic eye care, and comprehensive ophthalmology."
>
  <section class="border-b border-ink-100 bg-gradient-to-b from-brand-50/40 to-white">
    <div class="container-prose py-16 sm:py-20">
      <div class="eyebrow mb-3">Services</div>
      <h1 class="text-4xl sm:text-5xl font-semibold">What we treat</h1>
      <p class="mt-5 max-w-2xl text-lg text-ink-600 leading-relaxed">
        Tri-City Eye Care provides comprehensive medical and surgical ophthalmology. Surgical procedures are
        performed at Cambridge Memorial Hospital; consultations, injections, and laser are done in-clinic.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="container-prose py-14 space-y-10">
      {services.map((s) => (
        <article class="grid md:grid-cols-3 gap-6 pb-10 border-b border-ink-100 last:border-0">
          <div class="md:col-span-1">
            <h2 class="text-2xl font-semibold text-ink-900">{s.name}</h2>
            <ul class="mt-3 flex flex-wrap gap-1.5">
              {s.bullets.map((b) => (
                <li class="text-xs rounded-full bg-brand-50 text-brand-700 px-2.5 py-1">{b}</li>
              ))}
            </ul>
          </div>
          <div class="md:col-span-2 text-ink-700 leading-relaxed max-w-prose">
            {s.detail}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-ink-50/60 border-t border-ink-100">
    <div class="container-prose py-12">
      <div class="rounded-2xl border border-ink-100 bg-white p-6 sm:p-8 flex flex-col md:flex-row md:items-center gap-6">
        <div class="flex-1">
          <h2 class="text-xl font-semibold text-ink-900">Need a consult?</h2>
          <p class="mt-2 text-ink-600 leading-relaxed">
            We accept referrals from optometrists and family doctors. Patients are contacted to book once a referral arrives —
            no need to phone ahead.
          </p>
        </div>
        <a href="/referrals" class="btn-primary flex-shrink-0">Referral info →</a>
      </div>
    </div>
  </section>
</BaseLayout>
