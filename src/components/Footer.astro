---
import { clinic } from '@/data/clinic';
const year = new Date().getFullYear();
---
<footer class="mt-24 border-t border-ink-100 bg-ink-50">
  <div class="container-prose py-12 grid gap-10 md:grid-cols-3 text-sm">
    <div>
      <div class="flex items-center gap-2 mb-3">
        <span class="inline-block h-6 w-6 rounded-md bg-brand-700"></span>
        <span class="font-display text-base font-semibold text-ink-900">{clinic.name}</span>
      </div>
      <p class="text-ink-600 leading-relaxed">
        Comprehensive ophthalmology and surgical eye care in Kitchener, serving the Tri-City region by referral.
      </p>
    </div>
    <div>
      <h4 class="text-sm font-semibold text-ink-900 mb-3">Visit</h4>
      <address class="not-italic text-ink-600 leading-relaxed">
        {clinic.address.line1}<br/>
        {clinic.address.city}, {clinic.address.province} {clinic.address.postal}
      </address>
      <a href="/find-us" class="mt-3 inline-block text-brand-700 hover:text-brand-800">Directions & parking →</a>
    </div>
    <div>
      <h4 class="text-sm font-semibold text-ink-900 mb-3">Site</h4>
      <ul class="space-y-1.5 text-ink-600">
        <li><a href="/doctors" class="no-underline hover:text-ink-900">Our doctors</a></li>
        <li><a href="/services" class="no-underline hover:text-ink-900">Services</a></li>
        <li><a href="/referrals" class="no-underline hover:text-ink-900">For referring providers</a></li>
        <li><a href="/find-us" class="no-underline hover:text-ink-900">Find us</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-ink-100">
    <div class="container-prose py-5 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-ink-500">
      <span>© {year} {clinic.name}. All rights reserved.</span>
      <span>New patients seen by referral from an eye care provider.</span>
    </div>
  </div>
</footer>
