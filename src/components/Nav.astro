---
const links = [
  { href: '/doctors', label: 'Doctors' },
  { href: '/services', label: 'Services' },
  { href: '/find-us', label: 'Find Us' },
  { href: '/referrals', label: 'For Providers' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="sticky top-0 z-40 border-b border-ink-100 bg-white/85 backdrop-blur">
  <div class="container-prose flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2 no-underline">
      <span class="inline-block h-7 w-7 rounded-md bg-brand-700"></span>
      <span class="font-display text-lg font-semibold text-ink-900">Tri-City Eye Care</span>
    </a>
    <nav class="hidden md:block">
      <ul class="flex items-center gap-7 text-sm">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                'no-underline text-ink-600 hover:text-ink-900',
                path.startsWith(l.href) && 'text-ink-900 font-medium',
              ]}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
    <details class="md:hidden relative">
      <summary class="list-none cursor-pointer rounded-md p-2 text-ink-700 hover:bg-ink-50">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </summary>
      <ul class="absolute right-0 mt-2 w-56 rounded-lg border border-ink-100 bg-white py-2 shadow-lg">
        {links.map((l) => (
          <li>
            <a href={l.href} class="block px-4 py-2 text-sm text-ink-700 no-underline hover:bg-ink-50">{l.label}</a>
          </li>
        ))}
      </ul>
    </details>
  </div>
</header>
